[Unit]
Description=DaffyChat Daemon Manager
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/opt/daffychat/bin/daffydmd --config /etc/daffychat/daffychat.json
Restart=on-failure
RestartSec=2s
WorkingDirectory=/var/lib/daffychat

[Install]
WantedBy=multi-user.target
