build $builddir/rpm-package.stamp: package_artifact $builddir/libdaffy_core.a $builddir/daffy-backend $builddir/daffy-signaling $builddir/dssl-bindgen $builddir/dssl-docstrip $builddir/dssl-docgen $builddir/daffyscript
  format = rpm

build $builddir/pacman-package.stamp: package_artifact $builddir/libdaffy_core.a $builddir/daffy-backend $builddir/daffy-signaling $builddir/dssl-bindgen $builddir/dssl-docstrip $builddir/dssl-docgen $builddir/daffyscript
