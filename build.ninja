build $builddir/frontend_assets.txt: note
  message = Frontend assets: index.html, room.html, guide.html, 403.html, 404.html, bridge.js, app/{styles,state,api,hooks,components}/*.{css,js}

# DSSL toolchain
build $builddir/dssl_bindgen_main.o: cxx_dssl dssl/tools/bindgen/main.cpp
build $builddir/dssl-bindgen: link $builddir/dssl_bindgen_main.o
  ldflags =
build $builddir/dssl_docstrip_main.o: cxx_dssl dssl/tools/docstrip/main.cpp
build $builddir/dssl-docstrip: link $builddir/dssl_docstrip_main.o
  ldflags =
build $builddir/dssl_docgen_main.o: cxx_dssl dssl/tools/docgen/main.cpp
build $builddir/dssl-docgen: link $builddir/dssl_docgen_main.o
  ldflags =

# Daffyscript compiler
build $builddir/daffyc_main.o: cxx_daffyc daffyscript/main.cpp
build $builddir/daffyscript: link $builddir/daffyc_main.o
  ldflags =

