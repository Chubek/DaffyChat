builddir = build/ninja
cc = gcc
cxx = g++
python = python3
cflags = -std=c11 -Wall -Wextra -Wpedantic -Iinclude -Ithird_party/spdlog/include -Ithird_party/libsamplerate/include -Ithird_party/opus/include -Ithird_party/portaudio/include -Ithird_party/rnnoise/include -Ithird_party/uWebSockets/src -Ithird_party/uWebSockets/uSockets/src -DLIBUS_NO_SSL
cxxflags = -std=c++20 -Wall -Wextra -Wpedantic -Iinclude -Ithird_party/spdlog/include -Ithird_party/libdatachannel/include -Ithird_party/libdatachannel/include/rtc -Ithird_party/libsamplerate/include -Ithird_party/opus/include -Ithird_party/portaudio/include -Ithird_party/rnnoise/include -Ithird_party/uWebSockets/src -Ithird_party/uWebSockets/uSockets/src -DDAFFY_VERSION=\"0.1.0\" -DDAFFY_GIT_REVISION=\"workspace\" -DDAFFY_SOURCE_DIR=\"/home/chubakpdp11/nvme/daffychat\" -DLIBUS_NO_SSL -DUWS_NO_ZLIB
ldflags = -ldl -ldatachannel -lsrtp2
node = node

dssl_cxxflags = -std=c++20 -Wall -Wextra -Wpedantic -Ithird_party/PEGTL/include -Idssl
daffyc_cxxflags = -std=c++20 -Wall -Wextra -Wpedantic -Ithird_party/PEGTL/include -Idaffyc
rule cc
  command = mkdir -p $builddir && $cc $cflags -MMD -MF $out.d -c $in -o $out
  depfile = $out.d
  deps = gcc
  description = CC $out

rule cxx
  command = mkdir -p $builddir && $cxx $cxxflags -MMD -MF $out.d -c $in -o $out
  depfile = $out.d
  deps = gcc
  description = CXX $out

rule link
  command = mkdir -p $builddir && $cxx $in -o $out $ldflags
  description = LINK $out

rule run
  command = mkdir -p $builddir && $in && touch $out
  description = RUN $in

rule run_node
  command = mkdir -p $builddir && $node $in && touch $out
  description = RUN_NODE $in

rule note
  command = mkdir -p $builddir && printf "%s\n" "$message" > $out
  description = NOTE $out

rule package_artifact
  command = mkdir -p $builddir/packages && $python toolchain/package_artifact.py --format $format --source-dir . --build-dir $builddir --output-dir $builddir/packages --version 0.1.0 --stamp $out
  description = PACKAGE $format

rule cxx_dssl
  command = mkdir -p $builddir && $cxx $dssl_cxxflags -MMD -MF $out.d -c $in -o $out
  depfile = $out.d
  deps = gcc
  description = CXX_DSSL $out

rule cxx_daffyc
  command = mkdir -p $builddir && $cxx $daffyc_cxxflags -MMD -MF $out.d -c $in -o $out
  depfile = $out.d
  deps = gcc
  description = CXX_DAFFYC $out
build $builddir/build_info.o: cxx src/core/build_info.cpp
build $builddir/id.o: cxx src/core/id.cpp
build $builddir/logger.o: cxx src/core/logger.cpp
build $builddir/time.o: cxx src/core/time.cpp
build $builddir/app_config.o: cxx src/config/app_config.cpp
build $builddir/json.o: cxx src/util/json.cpp
build $builddir/event_bus.o: cxx src/runtime/event_bus.cpp
build $builddir/signaling_messages.o: cxx src/signaling/messages.cpp
build $builddir/signaling_client_facade.o: cxx src/signaling/signaling_client_facade.cpp
build $builddir/native_signaling_client.o: cxx src/signaling/native_signaling_client.cpp
build $builddir/signaling_admin_http_server.o: cxx src/signaling/admin_http_server.cpp
build $builddir/signaling_server.o: cxx src/signaling/server.cpp
build $builddir/uwebsockets_server.o: cxx src/signaling/uwebsockets_server.cpp
