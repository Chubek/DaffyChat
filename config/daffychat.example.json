{
  "server": {
    "bind_address": "0.0.0.0",
    "port": 7000,
    "public_base_url": "http://127.0.0.1:7000",
    "log_level": "info"
  },
  "signaling": {
    "bind_address": "0.0.0.0",
    "port": 7001,
    "max_room_size": 2,
    "ping_interval_ms": 15000,
    "ping_timeout_ms": 30000,
    "reconnect_grace_ms": 45000,
    "health_endpoint": "/healthz",
    "debug_rooms_endpoint": "/debug/rooms",
    "turn_credentials_endpoint": "/debug/turn-credentials",
    "stun_servers": [
      "stun:stun.l.google.com:19302"
    ],
    "allow_browser_signaling": true
  },
  "turn": {
    "uri": "turn:turn.example.com:3478?transport=udp",
    "username": "daffy",
    "password": "change-me",
    "credential_mode": "static"
  },
  "runtime_isolation": {
    "provider": "process",
    "workspace_root": "./var/rooms",
    "enable_lxc": false,
    "lxc_template": "busybox"
  },
  "services": {
    "ipc_url": "ipc:///tmp/daffychat-services.ipc",
    "builtin_service_dir": "./services/builtin",
    "generated_service_dir": "./services/generated",
    "enable_webhooks": true
  },
  "frontend_bridge": {
    "enabled": true,
    "asset_root": "./frontend",
    "bridge_endpoint": "/bridge/events",
    "allow_wasm_extensions": true,
    "voice_transport": "native-client-only"
  },
  "voice": {
    "preferred_input_device": "default",
    "preferred_output_device": "default",
    "preferred_capture_sample_rate": 48000,
    "preferred_playback_sample_rate": 48000,
    "preferred_channels": 1,
    "frames_per_buffer": 480,
    "playout_buffer_frames": 3,
    "max_playout_buffer_frames": 8,
    "enable_noise_suppression": true,
    "enable_metrics": true
  }
}
